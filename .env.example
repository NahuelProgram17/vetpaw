# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=web-production-eaeb4.up.railway.app,www.vetpaw.com.ar,vetpaw.com.ar
CSRF_TRUSTED_ORIGINS=https://web-production-eaeb4.up.railway.app,https://vetpaw-frontend.vercel.app,https://www.vetpaw.com.ar,https://vetpaw.com.ar
CORS_ALLOWED_ORIGINS=https://vetpaw-frontend.vercel.app,https://www.vetpaw.com.ar,https://vetpaw.com.ar

# PostgreSQL
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=replace-with-database-password
DB_HOST=replace-with-database-host
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Email / Resend
RESEND_API_KEY=replace-with-resend-api-key
DEFAULT_FROM_EMAIL=VetPaw <hola@vetpaw.com.ar>

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-secret

# Web Push
VAPID_PUBLIC_KEY=replace-with-public-key
VAPID_PRIVATE_KEY=replace-with-private-key
VAPID_SUBJECT=mailto:vetpaw.app@gmail.com
WEB_PUSH_TTL=86400
WEB_PUSH_TIMEOUT=5

# Seguridad gradual
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=same-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin

# Logs
LOG_LEVEL=INFO
